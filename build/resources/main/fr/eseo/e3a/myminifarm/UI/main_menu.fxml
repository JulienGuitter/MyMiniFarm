<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="menu" prefHeight="400.0" prefWidth="600.0" styleClass="home_background" stylesheets="@css/style.css"
           xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="fr.eseo.e3a.myminifarm.view.UI.MenuUI">
    <VBox alignment="CENTER" maxWidth="Infinity" prefWidth="600" spacing="20.0">
        <ImageView fitHeight="150.0" pickOnBounds="true" preserveRatio="true">
            <VBox.margin>
                <Insets bottom="50"/>
            </VBox.margin>
            <Image url="@../textures/UI/mainTitle.png"/>
        </ImageView>

        <Button onAction="#onPlayClicked" prefHeight="72.0" prefWidth="250.0" styleClass="home_button, btn_wood"
                text="Play" focusTraversable="false"/>
        <Button onAction="#onSettingsClicked" prefHeight="72.0" prefWidth="250.0"
                styleClass="home_button, btn_wood" text="Settings" focusTraversable="false"/>
        <Button onAction="#onQuitClicked" prefHeight="72.0" prefWidth="250.0" styleClass="home_button, btn_wood"
                text="Quit" focusTraversable="false"/>
    </VBox>
</StackPane>
