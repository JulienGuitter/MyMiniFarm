            fx:id="gameUI"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <StackPane>
            <fx:include source="modules/userInfo.fxml" fx:id="userInfo" />
