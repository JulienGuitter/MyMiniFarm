        </StackPane>

        <StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" scaleX="2.0" scaleY="2.0">
            <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../textures/UI/label_container.png" />
            </ImageView>
            <Label styleClass="pixelLabel, fixLabelCenter" text="SHOP">
                <StackPane.margin>
