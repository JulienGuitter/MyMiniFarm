<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="escapeMenu" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.eseo.e3a.myminifarm.view.UI.ShopUI">

    <StackPane styleClass="blackBack" />

    <StackPane alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity">
        <StackPane alignment="CENTER" maxHeight="500.0" maxWidth="800.0" styleClass="shop_back, scroll-pane">
            <VBox alignment="CENTER" maxWidth="Infinity" prefWidth="600" spacing="20.0">
