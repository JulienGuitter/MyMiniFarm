                <HBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <VBox alignment="CENTER_LEFT">
                        <Button onAction="#onChangeShopContainer" userData="0" alignment="CENTER" contentDisplay="TOP" graphicTextGap="0.0" maxHeight="90.0" maxWidth="90.0" minHeight="90.0" minWidth="90.0" prefHeight="90.0" prefWidth="90.0" styleClass="button, btn_wood, smallLabel" text="Seeds">
                            <graphic>
                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                    <Image url="@../textures/UI/seedBtn.png" />
                                </ImageView>
                            </graphic>
                        </Button>
<!--                        TODO : Reactivate when adding the animals -->
<!--                        <Button onAction="#onChangeShopContainer" userData="1" alignment="CENTER" contentDisplay="TOP" graphicTextGap="0.0" maxHeight="90.0" maxWidth="90.0" minHeight="90.0" minWidth="90.0" prefHeight="90.0" prefWidth="90.0" styleClass="button, btn_wood, smallLabel" text="Animals">-->
<!--                            <graphic>-->
<!--                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">-->
<!--                                    <Image url="@../textures/UI/animalBtn.png" />-->
<!--                                </ImageView>-->
<!--                            </graphic>-->
<!--                             <font>-->
<!--                                <Font size="10.0" />-->
<!--                             </font>-->
<!--                        </Button>-->
                        <Button onAction="#onChangeShopContainer" userData="2" alignment="CENTER" contentDisplay="TOP" graphicTextGap="0.0" maxHeight="90.0" maxWidth="90.0" minHeight="90.0" minWidth="90.0" prefHeight="90.0" prefWidth="90.0" styleClass="button, btn_wood, smallLabel" text="Machines">
                            <graphic>
                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                    <Image url="@../textures/UI/machineBtn.png" />
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Button>
                        <Button onAction="#onChangeShopContainer" userData="3" alignment="CENTER" contentDisplay="TOP" graphicTextGap="0.0" maxHeight="90.0" maxWidth="90.0" minHeight="90.0" minWidth="90.0" prefHeight="90.0" prefWidth="90.0" styleClass="button, btn_wood, smallLabel" text="Tools">
                            <graphic>
                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                    <Image url="@../textures/UI/toolBtn.png" />
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Button>
                        <Button onAction="#onChangeShopContainer" userData="4" alignment="CENTER" contentDisplay="TOP" graphicTextGap="0.0" maxHeight="90.0" maxWidth="90.0" minHeight="90.0" minWidth="90.0" prefHeight="90.0" prefWidth="90.0" styleClass="button, btn_wood, smallLabel" text="Product">
                            <graphic>
                                <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                                    <Image url="@../textures/UI/productBtn.png" />
                                </ImageView>
                            </graphic>
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Button>
                      <opaqueInsets>
                         <Insets right="10.0" />
                      </opaqueInsets>
                     </VBox>
                     <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" styleClass="scroll-pane" HBox.hgrow="ALWAYS">
                         <VBox fx:id="itemContainer" spacing="10.0">
                             <fx:include source="modules/shopItem.fxml" />

                             <padding>
                                <Insets right="10.0" />
                             </padding>
                         </VBox>
