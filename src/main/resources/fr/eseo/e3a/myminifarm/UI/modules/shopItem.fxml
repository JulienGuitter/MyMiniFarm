<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      stylesheets="@../css/style.css"
      fx:controller="fr.eseo.e3a.myminifarm.view.UI.modules.ShopItemUI"
      alignment="CENTER_LEFT" styleClass="shop_wood">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <ImageView fx:id="itemImage" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                <Image url="@../../textures/UI/seedBtn.png" />
            </ImageView>
            <Label fx:id="nameLabel" styleClass="pixelLabel" text="Seed 1" />
        </HBox>
        <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
            <VBox>
                <HBox fx:id="buyContainer" alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="buyPriceLabel" styleClass="pixelLabel" text="0 $" />
                    <Button styleClass="button, btn_wood" text="Buy" onAction="#buyProduct"/>
                </HBox>
                <HBox fx:id="sellContainer" alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="sellPriceLabel" styleClass="pixelLabel" text="0 $" />
                    <Button styleClass="button, btn_wood" text="Sell" onAction="#sellProduct"/>
                </HBox>
            </VBox>
        </HBox>
</HBox>
