<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="settings" prefHeight="400.0" prefWidth="600.0" styleClass="settings_background" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.eseo.e3a.myminifarm.view.UI.SettingsUI">

    <VBox fx:id="settingsContainer" alignment="CENTER" focusTraversable="false" maxWidth="-Infinity" spacing="20.0" styleClass="settingsContainer">
        <Label style="-fx-font-size: 20px" styleClass="pixelLabel, label_wood" text="Settings" />

        <HBox alignment="CENTER" spacing="20.0">
            <Button focusTraversable="false" onAction="#onGraphicsClicked" styleClass="button, btn_wood" text="Graphics" />
            <Button focusTraversable="false" onAction="#onKeysClicked" styleClass="button, btn_wood" text="Keys" />
            <Button focusTraversable="false" onAction="#onAudioClicked" styleClass="button, btn_wood" text="Audio" />
        </HBox>


        <StackPane fx:id="container" alignment="TOP_CENTER" focusTraversable="false" prefHeight="370.0" prefWidth="338.0" styleClass="interface_wood, scroll-pane">
            <ScrollPane fx:id="graphicsContainer" fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-background: transparent;" visible="true">

                    <VBox alignment="TOP_CENTER" fillWidth="true" focusTraversable="false" spacing="10">
                        <Label styleClass="pixelLabel, label_wood" text="Main Graphics" />
                        <HBox alignment="CENTER" spacing="20.0">
                            <Label styleClass="pixelLabel, fixLabelCenter" text="Fullscreen" />
                            <CheckBox fx:id="fullscreenCheckBox" focusTraversable="false" onAction="#onFullscreenChanged" selected="false" styleClass="checkbox" />
                        </HBox>
                    </VBox>
            </ScrollPane>

            <ScrollPane fx:id="keysScrol" fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-background: transparent;" visible="false">

                <GridPane fx:id="keysContainer" alignment="TOP_CENTER" hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" hgrow="ALWAYS" />
                        <ColumnConstraints halignment="RIGHT" hgrow="ALWAYS" />
                    </columnConstraints>
               <padding>
                  <Insets left="10.0" right="10.0" />
               </padding>
                </GridPane>
            </ScrollPane>

            <ScrollPane fx:id="audioContainer" fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-background: transparent;" visible="false">

                    <VBox alignment="TOP_CENTER" fillWidth="true" spacing="10">
                        <Label styleClass="pixelLabel, label_wood" text="Audio" />
                        <HBox alignment="CENTER" spacing="40.0">
                            <Label styleClass="pixelLabel, fixLabelCenter" text="Volume" />
                            <Slider fx:id="volumeSlider" max="100" min="0" onMouseDragged="#onMainVolumeChanged" onMouseReleased="#onMainVolumeChanged" prefWidth="200.0" styleClass="slider" value="50" />
                        </HBox>
                    </VBox>

            </ScrollPane>
        </StackPane>

        <Button focusTraversable="false" onAction="#onBackClicked" styleClass="button, btn_wood" text="Back" />

    </VBox>

</StackPane>
